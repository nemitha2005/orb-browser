{
  "name": "orb-browser",
  "version": "0.1.0",
  "description": "Orb — A focus-first open source browser",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:ts": "npm run build",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "quality": "npm run lint && npm run typecheck && npm run test && npm run build",
    "security:audit": "npm audit --audit-level=high",
    "start": "electron-vite preview",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "commitlint:last": "commitlint --from HEAD~1 --to HEAD",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/electron": "^1.6.12",
    "@types/node": "^20.11.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.orb.browser",
    "productName": "Orb",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
